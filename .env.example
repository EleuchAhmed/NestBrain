# .env.example — copy to .env and fill in your values

# ── Obsidian ─────────────────────────────────────────────────
# Absolute path to your Obsidian vault folder
OBSIDIAN_VAULT_PATH=/Users/yourname/ObsidianVault

# From Obsidian → Settings → Community Plugins → Local REST API
OBSIDIAN_API_KEY=

# ── Zotero ───────────────────────────────────────────────────
# From https://www.zotero.org/settings/keys → Create new key
ZOTERO_API_KEY=

# The "userID" from: curl -H "Zotero-API-Key: YOUR_KEY" \
#   https://api.zotero.org/keys/current
ZOTERO_LIBRARY_ID=

# Path to Zotero's storage folder (where PDFs live)
# Mac/Linux: ~/Zotero/storage
# Windows:   C:\Users\YOU\Zotero\storage
ZOTERO_STORAGE_PATH=~/Zotero/storage

# ── Docker host routing ──────────────────────────────────────
# Leave as-is for Mac/Windows.
# Linux: replace with output of: ip route | awk '/docker0/{print $9}'
ZOTERO_HOST=host.docker.internal
OBSIDIAN_HOST=host.docker.internal
