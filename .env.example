# ==============================================================================
# Nestbrain Research Pipeline - Environment Configuration
# ==============================================================================

# ------------------------------------------------------------------------------
# Zotero Configuration
# ------------------------------------------------------------------------------
# The local port Zotero is running on. Default is 23119.
ZOTERO_HOST=http://localhost:23119

# Your Zotero user ID (from zotero.org/settings/keys)
ZOTERO_LIBRARY_ID=1234567

# Your Zotero API Key (from zotero.org/settings/keys)
ZOTERO_API_KEY=YOUR_ZOTERO_API_KEY_HERE

# ------------------------------------------------------------------------------
# Obsidian Configuration
# ------------------------------------------------------------------------------
# Absolute path to your Obsidian vault where the AI notes will be saved.
# Example: C:\Users\YourName\Documents\Obsidian\MyVault
OBSIDIAN_VAULT_PATH=C:\Absolute\Path\To\Your\Vault

# ------------------------------------------------------------------------------
# NVIDIA NIM Configuration
# ------------------------------------------------------------------------------
# Your NVIDIA API Key for DeepSeek V3.1 integration
NVIDIA_API_KEY=YOUR_NVIDIA_API_KEY_HERE

# ------------------------------------------------------------------------------
# Docker GUI Configuration (Only needed if running via Docker)
# ------------------------------------------------------------------------------
# Instructs Docker where to send X11 UI rendering.
# Usually host.docker.internal:0.0 Windows running VcXsrv.
DISPLAY=host.docker.internal:0.0
QT_QPA_PLATFORM=xcb
